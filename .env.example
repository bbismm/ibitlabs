# ============================================
# iBitLabs — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# Never commit .env (already gitignored).
# ============================================

# ── COINBASE (required for trading) ──
# Generate at: https://www.coinbase.com/settings/api
# Required permissions: View, Trade (for futures). Do NOT enable Transfer.
CB_API_KEY=organizations/your-org-id/apiKeys/your-key-id
CB_API_SECRET="-----BEGIN EC PRIVATE KEY-----
YOUR_COINBASE_EC_PRIVATE_KEY_PEM_GOES_HERE_MULTI_LINE
-----END EC PRIVATE KEY-----"

# ── TELEGRAM (optional — auto-post trades to a public channel) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── NOTIFICATIONS (optional — push alerts on bot drift / position issues) ──
NTFY_TOPIC=
NOTIFY_IMESSAGE=

# ── AUTOPILOT (optional — encrypted customer key vault, dormant in current setup) ──
AUTOPILOT_MASTER_KEY=
