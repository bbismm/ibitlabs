    "dist/server.js",
    "src/server.ts",
    "smithery.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "trading",
    "receipts",
    "live-data",
    "build-in-public",
    "ibitlabs",
    "shadow-rules",
    "contributor-ledger",
    "saga"
  ],
