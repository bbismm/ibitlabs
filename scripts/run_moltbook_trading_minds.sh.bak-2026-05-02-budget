#!/bin/zsh
#
# moltbook-trading-minds — launchd-driven runner
#
# Publishes the daily Trading Minds post as @ibitlabs_reporter (separate
# persona from @ibitlabs_agent which is handled by moltbook-brand-builder).
#
# Schedule: launchd plist com.ibitlabs.moltbook-trading-minds fires daily at
# 09:30 LOCAL — 3.5h after the brand-builder 06:00 fire to avoid
# back-to-back publish bursts on the same submolt (s/general).
#
# Logs: ~/ibitlabs/logs/moltbook-trading-minds/<YYYYMMDD-HHMMSS>.log
#
# To run manually for testing:
#   ~/ibitlabs/scripts/run_moltbook_trading_minds.sh
#
# History:
#   - 2026-04-13 → 2026-04-27: ran as ~/Documents/Claude/Scheduled/moltbook-daily-post
#     via Cowork scheduled-tasks MCP. Archived 2026-04-27 with 3 dailies.
#   - 2026-04-30: revived as launchd job, slim canonical SKILL at
#     ~/.claude/scheduled-tasks/moltbook-trading-minds/SKILL.md, NEW ledger
#     hook (Step 4) feeding contributors.json queued_for_review.
#   - 2026-04-30: reporter API key rotated; new key in Keychain under
#     service ibitlabs-moltbook-reporter (NEVER paste plaintext key here).

set -u
set -o pipefail

LOG_DIR="$HOME/ibitlabs/logs/moltbook-trading-minds"
TS="$(date -u +%Y%m%d-%H%M%S)"
LOG="$LOG_DIR/$TS.log"
SKILL_FILE="$HOME/.claude/scheduled-tasks/moltbook-trading-minds/SKILL.md"

mkdir -p "$LOG_DIR"

{
  echo "=== moltbook-trading-minds run @ $(date -u +%Y-%m-%dT%H:%M:%SZ) ==="
  echo "host: $(hostname)  user: $(whoami)  cwd: $(pwd)"
  echo "claude: $(/opt/homebrew/bin/claude --version 2>/dev/null)"
  echo "skill source: $SKILL_FILE"
  echo "---"

  if [[ ! -f "$SKILL_FILE" ]]; then
    echo "FATAL: skill file not found at $SKILL_FILE"
    exit 1
  fi

  # Verify reporter key is reachable (without printing it).
  if ! /usr/bin/security find-generic-password -s ibitlabs-moltbook-reporter -a ibitlabs -w >/dev/null 2>&1; then
    echo "FATAL: reporter Keychain entry 'ibitlabs-moltbook-reporter' not found."
    exit 1
  fi
  echo "keychain: ibitlabs-moltbook-reporter reachable (key sha-prefix: $(/usr/bin/security find-generic-password -s ibitlabs-moltbook-reporter -a ibitlabs -w | shasum -a 256 | cut -c1-8))"
  echo "---"

  PREAMBLE="UNATTENDED CRON RUN — no human is watching. This is a launchd-driven
daily 09:30 local Trading Minds publish run, posting as @ibitlabs_reporter
(NOT @ibitlabs_agent — different persona, different voice).

Reporter Moltbook key: read at runtime from Keychain via
\`security find-generic-password -s ibitlabs-moltbook-reporter -a ibitlabs -w\`.
NEVER write the key to disk and NEVER print it in any log line or output.

Execute autonomously. Do NOT pause for confirmation. The skip rules in
SKILL.md ARE the approval — if no qualifying frame, exit 0 with a one-line
skip log. Silence is the correct output on a slow day; do NOT publish a
filler post.

If publish succeeds, append a frame candidate to
~/ibitlabs/web/public/data/contributors.json queued_for_review per Step 4.
If the ledger append fails after publish, log warn but exit 0 — the post is
live and the operator will reconcile.

Skill instructions follow:
"
  printf '%s\n%s\n' "$PREAMBLE" "$(cat "$SKILL_FILE")" | /opt/homebrew/bin/claude \
    -p \
    --dangerously-skip-permissions \
    --max-budget-usd 1.50 \
    --model sonnet \
    --add-dir "$HOME/ibitlabs"

  STATUS=$?
  echo ""
  echo "---"
  echo "=== claude exit status: $STATUS ==="
  exit $STATUS
} 2>&1 | tee -a "$LOG"
