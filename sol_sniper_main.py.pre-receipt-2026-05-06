# ── Regime gate ────────────────────────────────────────────────────────────
# Off by default. When STRATEGY_REGIME_GATE=1, sniper will refuse signals
# whose direction conflicts with the dominant 30-day regime: in an up-biased
# 30d window, SHORT signals get blocked; in a down-biased window, LONGs get
# blocked. Sideways → both allowed. The discovery that motivated this:
# 2026-04-10 regime_watch found training (180d) was 56% down but live 30d is
# 51% up, a +33pp drift on the `up` label. Strategy parameters are short-
# biased; we want the OPTION to refuse trades it was never trained for.
#
# Tuning knobs (conservative defaults):
#   STRATEGY_REGIME_GATE         — "1" / "true" to enable (default off)
#   REGIME_GATE_DOMINANCE_PCT    — pp gap that defines "dominant" (default 25)
#   REGIME_GATE_WINDOW_DAYS      — rolling window in days (default 30)
#   REGIME_GATE_REFRESH_SECONDS  — cache TTL (default 3600 = 1 hour)
REGIME_GATE_ENABLED = os.environ.get("STRATEGY_REGIME_GATE", "").lower() in ("1", "true", "yes")
REGIME_GATE_DOMINANCE_PCT = float(os.environ.get("REGIME_GATE_DOMINANCE_PCT", "25"))
REGIME_GATE_WINDOW_DAYS = int(os.environ.get("REGIME_GATE_WINDOW_DAYS", "30"))
REGIME_GATE_REFRESH_SECONDS = int(os.environ.get("REGIME_GATE_REFRESH_SECONDS", "3600"))
_regime_gate_cache = {"ts": 0, "verdict": None, "last_success_ts": 0, "last_warn_ts": 0}
# last_success_ts tracks when _compute_regime_verdict last actually succeeded
# (not just when it was last called). Watchdog: if too long passes without a
# success while the gate is enabled, we log a loud warning. Without this, the
# fail-open semantics could leave the gate silently dead for days.
REGIME_GATE_STALE_SECONDS = int(os.environ.get("REGIME_GATE_STALE_SECONDS", "21600"))  # 6h


def _compute_regime_verdict(exchange, config):
    """Pull 1h candles for the last REGIME_GATE_WINDOW_DAYS, classify each
    bar with the same SniperSignalEngine logic, return the dominance verdict.
    Cached for REGIME_GATE_REFRESH_SECONDS so this doesn't run every scan.
    Returns ("up_dominant"|"down_dominant"|"neutral", up_pct, down_pct) or None on error.

    Uses Coinbase public REST directly (same as backtest_sniper_leverage.fetch_candles)
    instead of exchange.fetch_ohlcv, because the wrapped CCXT call has a 350-bar
    hard limit per request and we need ~720 bars for a 30-day 1h window.
    `exchange` is accepted but unused — kept in the signature so the caller doesn't
    have to know which path the gate uses."""
    import json as _json
    import urllib.request as _urlreq

    now = time.time()
    if _regime_gate_cache["verdict"] and (now - _regime_gate_cache["ts"]) < REGIME_GATE_REFRESH_SECONDS:
        return _regime_gate_cache["verdict"]
    try:
        # We need REGIME_GATE_WINDOW_DAYS of 1h bars PLUS warmup for the
        # rolling regime classifier (which looks back regime_window_hours).
        warmup_hours = config.regime_window_hours + 24
        total_hours = REGIME_GATE_WINDOW_DAYS * 24 + warmup_hours
        granularity = 3600  # 1h
        end_ts = int(now)
        start_ts = end_ts - total_hours * granularity
        bars = []
        batch_seconds = 300 * granularity  # 300 bars per request, under the 350 limit
        cur = start_ts
        while cur < end_ts:
            cur_end = min(cur + batch_seconds, end_ts)
            url = (f"https://api.exchange.coinbase.com/products/SOL-USD/candles"
                   f"?granularity={granularity}&start={cur}&end={cur_end}")
            req = _urlreq.Request(url, headers={"User-Agent": "RegimeGate/1.0"})
            with _urlreq.urlopen(req, timeout=10) as resp:
                data = _json.loads(resp.read())
            for row in data:
                bars.append((row[0], row[4]))  # (ts, close)
            cur = cur_end
        bars.sort(key=lambda x: x[0])
        # Dedup
        seen = set()
        uniq = []
        for ts, close in bars:
            if ts not in seen:
                seen.add(ts)
                uniq.append(close)
        if len(uniq) < warmup_hours + 24:
            return None
        closes = uniq
        # Classify each bar in the WINDOW (not the warmup) using the live engine's logic.
        # We use the same arithmetic the engine's _classify_regime uses, inlined to
        # avoid instantiating a SniperSignalEngine for every cache miss.
        regimes = {"up": 0, "down": 0, "sideways": 0}
        window = config.regime_window_hours
        start_idx = max(window, len(closes) - REGIME_GATE_WINDOW_DAYS * 24)
        for j in range(start_idx, len(closes)):
            recent = closes[j - window:j]
            if len(recent) < 48:
                continue
            start_price = sum(recent[:24]) / 24
            end_price = sum(recent[-24:]) / 24
            change = (end_price - start_price) / start_price if start_price else 0
            if change > config.regime_up_threshold:
                regimes["up"] += 1
            elif change < config.regime_down_threshold:
                regimes["down"] += 1
            else:
                regimes["sideways"] += 1
        total = sum(regimes.values()) or 1
        up_pct = regimes["up"] / total * 100
        down_pct = regimes["down"] / total * 100
        gap = up_pct - down_pct
        if gap > REGIME_GATE_DOMINANCE_PCT:
            verdict = ("up_dominant", up_pct, down_pct)
        elif gap < -REGIME_GATE_DOMINANCE_PCT:
            verdict = ("down_dominant", up_pct, down_pct)
        else:
            verdict = ("neutral", up_pct, down_pct)
        _regime_gate_cache["ts"] = now
        _regime_gate_cache["verdict"] = verdict
        _regime_gate_cache["last_success_ts"] = now
        return verdict
    except Exception as e:
        logger.warning(f"[SNIPER] Regime gate compute failed: {e}")
        # Watchdog: if the gate is enabled and hasn't successfully computed
        # in REGIME_GATE_STALE_SECONDS, scream loudly. fail-open means we keep
        # trading, but we want a paper trail so a silently dead gate doesn't
        # masquerade as "everything fine".
        if REGIME_GATE_ENABLED:
            last_ok = _regime_gate_cache.get("last_success_ts", 0)
            stale = now - last_ok if last_ok else float("inf")
            if stale > REGIME_GATE_STALE_SECONDS:
                # rate-limit the loud warning to once per hour
                if now - _regime_gate_cache.get("last_warn_ts", 0) > 3600:
                    age_h = stale / 3600 if stale != float("inf") else -1
                    logger.error(
                        f"[SNIPER] Regime gate STALE: no successful verdict in "
                        f"{age_h:.1f}h (threshold {REGIME_GATE_STALE_SECONDS/3600:.0f}h). "
                        f"Gate is failing-open — trades are NOT being filtered."
                    )
                    _regime_gate_cache["last_warn_ts"] = now
        return None


def regime_gate_blocks(direction, exchange, config):
    """Return (blocked: bool, reason: str). Off when REGIME_GATE_ENABLED=False."""
    if not REGIME_GATE_ENABLED:
        return (False, "")
    verdict = _compute_regime_verdict(exchange, config)
    if not verdict:
        return (False, "")  # fail-open: if we can't compute, don't block
    label, up_pct, down_pct = verdict
    if label == "up_dominant" and direction == "short":
        return (True, f"30d up-dominant ({up_pct:.0f}% up vs {down_pct:.0f}% down) — short refused")
    if label == "down_dominant" and direction == "long":
        return (True, f"30d down-dominant ({down_pct:.0f}% down vs {up_pct:.0f}% up) — long refused")
    return (False, "")

