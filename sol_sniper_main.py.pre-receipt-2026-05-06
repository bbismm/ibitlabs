            open_orders = exchange.fetch_open_orders(config.symbol)
            if open_orders:
                order_ids = [o["id"] for o in open_orders]
                exchange.cancel_orders(order_ids)
                logger.info(f"[SNIPER] Startup: cancelled {len(order_ids)} open orders")
            else:
                logger.info("[SNIPER] Startup: no open orders to cancel")
        except Exception as e:
            logger.warning(f"[SNIPER] Failed to cancel open orders on startup: {e}")
    consecutive_sl = 0          # Circuit breaker: count consecutive SLs
    CIRCUIT_BREAKER_LIMIT = 3   # Pause after 3 consecutive SLs
    CIRCUIT_BREAKER_HOURS = 24  # Pause duration
    ATR_VOLATILITY_GATE = 0.04  # Skip signals when ATR > 4%
    TP_COOLDOWN_SECONDS = 900   # 15min cooldown after TP/trailing close
    GRID_LOSS_PCT = 0.01        # Skip Grid→Sniper if Grid unrealized loss > 1% of GRID_SIZE per level
    grid_disabled = _args.no_grid
    grid = None if grid_disabled else MicroGrid(exchange, config, paper_mode=paper_mode)
    grid_notifier = Notifier()
    grid_was_active = False

    logger.info(f"[SNIPER] Symbol: {config.symbol}")
    logger.info(f"[SNIPER] TP={config.tp_pct:.1%} SL={config.sl_pct:.1%} "
                f"Trail={config.trailing_activate_pct:.1%}/{config.trailing_stop_pct:.1%}")
