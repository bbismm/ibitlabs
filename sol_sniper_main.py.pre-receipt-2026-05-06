                # Optional reverse-signal exit (throttled to scan_interval so the
                # extra scan_entry() call doesn't hammer the API on every tick).
                if reverse_exit_enabled and (now - last_reverse_check) >= config.scan_interval_seconds:
                    last_reverse_check = now
                    pos_dir = executor.position.get("direction") if executor.position else None
                    if pos_dir and signals_engine.check_reverse_exit(pos_dir):
                        check = {
                            "action": "close_reverse",
                            "reason": f"Reverse signal ({'short' if pos_dir=='long' else 'long'}) fired",
                            "pnl_pct": 0,
                            "pnl_usd": 0,
                            "current_price": 0,
                        }
                    else:
                        check = executor.check_position()
                else:
                    check = executor.check_position()
                action = check["action"]

                if action == "hold":
                    pnl_pct = check.get("pnl_pct", 0)
                    pnl_usd = check.get("pnl_usd", 0)
                    cur = check.get("current_price", 0)
                    if int(now) % 60 < config.price_check_seconds:
                        logger.info(
                            f"[SNIPER] {executor.get_position_info()} | "
                            f"Current: ${cur:.2f} | PnL: {pnl_pct:+.2%} (${pnl_usd:+.2f})"
                        )

                elif action.startswith("close_"):
                    # TP/trailing stop = limit, SL/timeout = market
                    use_market = action in ("close_sl", "close_timeout")
                    result = executor.close_position(check["reason"], use_market=use_market)

                    pnl = result.get("pnl_usd", 0)
                    tracker.record(pnl)

                    # Update balance for daily target calculation
                    try:
                        _bal = exchange.fetch_balance()
                        free_usd = float(_bal.get("total", {}).get("USD", 0) or free_usd)
                    except Exception:
                        pass

                    # Broadcast close to users (skipped in quiet/shadow mode)
                    if not QUIET_MODE:
                        try:
                            broadcast_close(
                                direction=result.get("direction", "unknown"),
                                entry_price=result.get("entry_price", 0),
                                exit_price=result.get("fill_price", check.get("current_price", 0)),
                                pnl_usd=pnl,
                                pnl_pct=result.get("pnl_pct", check.get("pnl_pct", 0)) * 100,
                                reason=action.replace("close_", ""),
                            )
                        except Exception as e:
                            logger.debug(f"[BROADCAST] Close broadcast error: {e}")

                    # Resume Grid if it was paused during handoff
                    if grid and grid.paused:
                        grid.resume()
                        logger.info("[GRID] Resumed after Sniper exit")

                    # Cooldown after stop loss + circuit breaker
                    if action == "close_sl":
                        consecutive_sl += 1
                        if consecutive_sl >= CIRCUIT_BREAKER_LIMIT:
                            cooldown_until = now + CIRCUIT_BREAKER_HOURS * 3600
                            logger.warning(
                                f"[SNIPER] CIRCUIT BREAKER — {consecutive_sl} consecutive SLs! "
                                f"Pausing {CIRCUIT_BREAKER_HOURS}h until "
                                f"{time.strftime('%m-%d %H:%M', time.localtime(cooldown_until))}"
                            )
                            if not QUIET_MODE:
                                send_push("CIRCUIT BREAKER",
                                          f"{consecutive_sl} consecutive SLs — pausing {CIRCUIT_BREAKER_HOURS}h")
                        else:
                            cooldown_until = now + config.cooldown_seconds
                            logger.info(
                                f"[SNIPER] Cooldown {config.cooldown_seconds // 3600}h "
                                f"(SL #{consecutive_sl}, breaker at {CIRCUIT_BREAKER_LIMIT}) "
                                f"(until {time.strftime('%H:%M', time.localtime(cooldown_until))})"
                            )
                    elif action in ("close_tp", "close_trailing", "close_reverse"):
                        # TP/trailing/reverse: short cooldown to avoid chasing
                        cooldown_until = now + TP_COOLDOWN_SECONDS
                        logger.info(
                            f"[SNIPER] Post-{action.replace('close_','')} cooldown "
                            f"{TP_COOLDOWN_SECONDS // 60}min "
                            f"(until {time.strftime('%H:%M', time.localtime(cooldown_until))})"
                        )
                        # Mode C: record opposite direction so we refuse re-entry
                        # until that signal stops firing.
                        if action == "close_reverse" and reverse_exit_mode_c:
                            closed_dir = result.get("direction")
                            reentry_gate_dir = "short" if closed_dir == "long" else "long"
                            logger.info(
                                f"[SNIPER] Mode C gate armed: blocking {reentry_gate_dir} "
                                f"entries until reverse signal clears"
                            )
                        if pnl > 0:
                            consecutive_sl = 0
                    else:
                        # Win or non-SL close resets the counter
                        if pnl > 0:
                            consecutive_sl = 0

                # Persist state during position hold (trailing, highest_pnl, etc.)
                if hasattr(executor, '_save_state'):
                    try:
                        executor._save_state(grid.get_status() if grid else {})
                    except Exception:
                        pass

                time.sleep(config.price_check_seconds)
                continue

            # ── No position: scan for signals ──
            if now - last_scan < config.scan_interval_seconds:
                time.sleep(1)
                continue

            last_scan = now

            # In cooldown
            if now < cooldown_until:
                remaining = int(cooldown_until - now)
                if remaining % 300 < config.scan_interval_seconds:
                    logger.info(f"[SNIPER] In cooldown, {remaining // 60} min remaining")
                time.sleep(config.scan_interval_seconds)
                continue

            # ── ATR volatility gate: skip signals in extreme volatility ──
            atr_blocked = False
            try:
                atr_info = grid.get_atr_info() if grid else {"atr_pct": 0}
                atr_pct = atr_info.get("atr_pct", 0)
                if atr_pct > ATR_VOLATILITY_GATE:
                    atr_blocked = True
                    if int(now) % 300 < config.scan_interval_seconds:
                        logger.info(
                            f"[SNIPER] Volatility gate: ATR {atr_pct:.2%} > {ATR_VOLATILITY_GATE:.0%} — "
                            f"skipping signals (mean reversion unreliable)"
                        )
            except Exception:
                pass

            # Scan for sniper signal
            signal = signals_engine.scan_entry() if not atr_blocked else None

            # Mode C re-entry gate: after a reverse-signal exit, refuse new
            # entries in the direction that triggered the reverse until the
            # opposite signal stops firing. Once scan_entry() returns None
            # (or the same side we closed on), the gate clears.
            if signal and reentry_gate_dir is not None:
                if signal["direction"] == reentry_gate_dir:
                    logger.info(
                        f"[SNIPER] Mode C gate: skipping {reentry_gate_dir} — "
                        f"reverse signal still firing"
                    )
                    time.sleep(config.scan_interval_seconds)
                    continue
                else:
                    logger.info(
                        f"[SNIPER] Mode C gate cleared: reverse signal stopped "
                        f"(now firing {signal['direction']})"
                    )
                    reentry_gate_dir = None
            elif not signal and reentry_gate_dir is not None:
                # No signal at all — also clears the gate (opposite isn't firing)
                reentry_gate_dir = None

            if signal:
                # ── Regime gate (off by default; opt in via env) ──
                # Refuses signals whose direction conflicts with the dominant
                # 30-day regime. Lets us run the same engine on shadow with
                # gate=ON and live with gate=OFF, then compare which one wins.
                blocked, gate_reason = regime_gate_blocks(
                    signal["direction"], exchange, config
                )
                if blocked:
                    logger.info(f"[SNIPER] Regime gate: {gate_reason} — skipping")
                    time.sleep(config.scan_interval_seconds)
                    continue

                # ── Grid → Sniper handoff: use grid edge for better entry ──
                grid_edge_price = None
                if grid and grid.active and grid.grid_orders:
                    # Short → use grid top (highest sell level) for better entry
                    # Long  → use grid bottom (lowest buy level) for better entry
                    if signal["direction"] == "short":
                        sell_prices = [o["price"] for o in grid.grid_orders.values()
                                       if o["side"] == "sell"]
                        if sell_prices:
                            grid_edge_price = max(sell_prices)
                    else:
                        buy_prices = [o["price"] for o in grid.grid_orders.values()
                                      if o["side"] == "buy"]
                        if buy_prices:
                            grid_edge_price = min(buy_prices)

                # Smart Grid → Sniper handoff
                if grid and (grid.active or grid.grid_orders):
                    handoff_trades = []
                    skip_signal = False
                    try:
                        t = exchange.fetch_ticker(config.symbol)
                        cur_price = t["last"]

                        # P2: Check Grid unrealized loss — skip handoff if too painful
                        # Threshold scales with GRID_SIZE (1% per filled level)
                        filled_count = sum(
                            1 for o in grid.grid_orders.values()
                            if o.get("filled") and o.get("entry_price")
                        )
                        loss_threshold = GRID_LOSS_PCT * GRID_SIZE * max(filled_count, 1)
                        grid_upnl = grid.get_unrealized_pnl(cur_price)
                        if grid_upnl < -loss_threshold:
                            logger.info(
                                f"[GRID] Handoff skipped — unrealized ${grid_upnl:+.2f} "
                                f"exceeds -${loss_threshold:.2f} threshold ({filled_count} levels), keeping Grid"
                            )
                            skip_signal = True
                        else:
                            # P0: Only close opposite-direction positions, keep same-direction
                            handoff_trades = grid.close_opposite_positions(
                                cur_price, signal["direction"]
                            ) or []

                            # Check if any same-direction positions remain
                            same_filled = sum(
                                1 for o in grid.grid_orders.values()
                                if o.get("filled") and o.get("entry_price")
                            )
                            if same_filled == 0:
                                # No positions left, fully deactivate grid
                                grid.grid_orders = {}
                                grid.active = False
                                grid._clear_state_file()
                                logger.info("[GRID] No same-direction positions, fully deactivated")
                            else:
                                # Pause grid (keep same-direction positions alive)
                                grid.pause()
                                logger.info(
                                    f"[GRID] Paused — kept {same_filled} same-direction positions"
                                )
                    except Exception as e:
                        logger.warning(f"[GRID] Handoff close failed: {e}")
                        grid.grid_orders = {}
                        grid.active = False

                    if skip_signal:
                        time.sleep(config.scan_interval_seconds)
                        continue

                    # Sync closed positions to balance + DB
                    for gt in handoff_trades:
                        tracker.record(gt["pnl"])
                        if paper_mode and hasattr(executor, 'cash'):
                            executor.cash += gt["pnl"]
                        close_side = "GRID_CLOSE_BUY" if gt["side"] == "buy" else "GRID_CLOSE_SELL"
                        db.log_trade(
                            config.symbol, close_side,
                            gt["entry"], GRID_SIZE / gt["entry"],
                            GRID_SIZE, gt["pnl"],
                            direction="long" if gt["side"] == "buy" else "short",
                            entry_price=gt.get("entry"),
                            exit_price=gt.get("exit"),
                            exit_reason="grid_handoff",
                            strategy_version="grid_v1",
                            strategy_intent="grid_mean_reversion",
                            trigger_rule="grid_level",
                            instance_name=getattr(config, "instance_name", "live"),
                        )
                    # Notify
                    if grid_was_active:
                        if not QUIET_MODE:
                            grid_notifier._send(
                                "GRID → SNIPER",
                                f"{signal['direction'].upper()} | Grid PnL ${grid.pnl:+.2f}",
                            )
                            try:
                                broadcast_grid_event("to_sniper", {"direction": signal["direction"]})
                            except Exception:
                                pass
                        grid_was_active = False

                # Pass grid edge price to signal for better entry
                if grid_edge_price:
                    signal["grid_edge_price"] = grid_edge_price
                    d_str = signal["direction"].upper()
                    logger.info(f"[SNIPER] Using grid edge ${grid_edge_price:.2f} for {d_str} entry")

                # Refresh balance + equity. The "floor" check uses TOTAL equity
                # (cash + locked margin + unrealized PnL), not free cash —
                # otherwise it would trip the moment a position locks margin.
                equity_usd = 0.0
                mark_price = signal.get("entry_price") or signal.get("price") or 0
                if paper_mode:
                    free_usd = executor.get_balance()
                    try:
                        equity_usd = executor.get_equity(mark_price)
                    except Exception:
                        equity_usd = free_usd
                else:
                    try:
                        balance = exchange.fetch_balance()
                        free_usd = float(balance.get("free", {}).get("USD", 0) or 0)
                        equity_usd = float(balance.get("total", {}).get("USD", 0) or 0)
                        if equity_usd <= 0:
                            equity_usd = free_usd
                    except Exception:
                        pass

                if free_usd < 10:
                    logger.warning(f"[{mode_str}] Low balance: ${free_usd:.2f}")
                    time.sleep(config.scan_interval_seconds)
                    continue

                # Capital safety floor: refuse to open new positions when total
                # equity drops below the floor. Existing positions keep running
                # (no panic exit). Push one alert on first breach.
                if MIN_CASH_FLOOR > 0 and equity_usd < MIN_CASH_FLOOR:
                    global _floor_alert_sent
                    logger.warning(
                        f"[{mode_str}] Equity floor breach: ${equity_usd:.2f} "
                        f"< ${MIN_CASH_FLOOR:.2f} — refusing new positions"
                    )
                    if not _floor_alert_sent and not QUIET_MODE:
                        try:
                            send_push(
                                f"SNIPER PAUSED — equity floor",
                                f"Equity ${equity_usd:.2f} < floor ${MIN_CASH_FLOOR:.2f}. "
                                f"No new positions opening. Existing trades unaffected.",
                            )
                        except Exception as e:
                            logger.debug(f"[FLOOR] push failed: {e}")
                        _floor_alert_sent = True
                    time.sleep(config.scan_interval_seconds)
                    continue
                # Reset the dedupe flag when we recover above the floor.
                if _floor_alert_sent and equity_usd >= MIN_CASH_FLOOR:
                    _floor_alert_sent = False
                    logger.info(f"[{mode_str}] Equity recovered above floor — resuming opens")

                # Fetch real-time buying power (accounts for grid margin usage)
                if not paper_mode:
                    try:
                        _live_bal = exchange.fetch_balance()
                        _open_balance = float(_live_bal.get("free", {}).get("USD", 0) or 0)
                    except Exception:
                        _open_balance = free_usd
                else:
                    _open_balance = executor.get_balance() if hasattr(executor, 'get_balance') else free_usd
                success = executor.open_position(signal, _open_balance)
                if success:
                    d = signal["direction"].upper()
                    # Report total equity (cash + locked margin + unrealized PnL),
                    # not pre-trade free_usd. free_usd was fetched before
                    # executor.open_position() locked margin, so it overstates
                    # the post-open free cash. Total equity is what /api/live-status
                    # publishes and is what the close-side notification uses.
                    bal_after = executor.get_balance() if paper_mode else equity_usd
                    logger.info(
                        f"[{mode_str}] {d} opened | "
                        f"Balance: ${bal_after:.2f} | "
                        f"Reasons: {', '.join(signal['reasons'])}"
                    )
                    if not QUIET_MODE:
                        grid_notifier.on_position_opened(
                            signal["direction"],
                            signal.get("entry_price", signal.get("price", 0)),
                            signal.get("reasons", []), bal_after,
                        )
                        # Broadcast open signal to Telegram subscribers
                        try:
                            broadcast_signal(signal)
                        except Exception as e:
                            logger.debug(f"[BROADCAST] Signal broadcast error: {e}")
            else:
                # No sniper signal — run micro-grid (regime-adaptive direction)
                # Get current regime for grid direction control
                _grid_regime = "sideways"
                try:
                    _1h = exchange.fetch_ohlcv(config.symbol, config.trend_timeframe, limit=300)
                    _c1h = [c[4] for c in _1h]
                    _grid_regime = signals_engine._classify_regime(_c1h)
                except Exception:
                    pass
                if grid and grid.should_activate(_grid_regime):
                    # Notify on grid activation
                    if grid.active and not grid_was_active:
                        if not QUIET_MODE:
                            grid_notifier.on_grid_created("SOL", 6, "sideways")
                            try:
                                broadcast_grid_event("activated", {"mid_price": grid.mid_price})
                            except Exception:
                                pass
                        grid_was_active = True

                    grid_result = grid.check_and_execute()
                    if grid_result:
                        # Record fills (entries) to DB + notify
                        for gf in grid_result.get("fills", []):
                            gf_side = "GRID_BUY" if gf["side"] == "buy" else "GRID_SELL"
                            db.log_trade(
                                config.symbol, gf_side,
                                gf["price"], GRID_SIZE / gf["price"],
                                GRID_SIZE, 0,  # pnl=0, open position
                                direction="long" if gf["side"] == "buy" else "short",
                                entry_price=gf["price"],
                                exit_reason="grid_open",
                                strategy_version="grid_v1",
                                strategy_intent="grid_mean_reversion",
                                trigger_rule="grid_level",
                                instance_name=getattr(config, "instance_name", "live"),
                            )
                            # Push grid fill notification
                            if not QUIET_MODE:
                                grid_notifier._send(
                                    f"GRID FILL {gf['side'].upper()}",
                                    f"SOL @ ${gf['price']:.2f} | ${gf['size']:.0f} | TP ${gf['tp']:.2f}",
                                )
                                try:
                                    broadcast_grid_event("fill", {"side": gf["side"], "price": gf["price"], "size": gf["size"], "tp": gf["tp"]})
                                except Exception:
                                    pass

                        # Record completed trades (TP/drift close)
                        for gt in grid_result.get("trades", []):
                            tracker.record(gt["pnl"])

                            # Sync PnL to executor balance
                            if paper_mode and hasattr(executor, 'cash'):
                                executor.cash += gt["pnl"]

                            # Write completed trade to DB (entry price as price, pnl filled)
                            gt_side = "GRID_BUY_TP" if gt["side"] == "buy" else "GRID_SELL_TP"
                            if gt.get("reason") == "drift_close":
                                gt_side = "GRID_CLOSE_BUY" if gt["side"] == "buy" else "GRID_CLOSE_SELL"
                            db.log_trade(
                                config.symbol, gt_side,
                                gt["entry"], GRID_SIZE / gt["entry"],
                                GRID_SIZE, gt["pnl"],
                                direction="long" if gt["side"] == "buy" else "short",
                                entry_price=gt.get("entry"),
                                exit_price=gt.get("exit"),
                                exit_reason="grid_drift" if gt.get("reason") == "drift_close" else "grid_tp",
                                strategy_version="grid_v1",
                                strategy_intent="grid_mean_reversion",
                                trigger_rule="grid_level",
                                instance_name=getattr(config, "instance_name", "live"),
                            )

                            # Notify each grid trade (audience-facing)
                            try:
                                if paper_mode:
                                    _bal = executor.cash if hasattr(executor, 'cash') else 0
                                else:
                                    _bal = float(exchange.fetch_balance().get("total", {}).get("USD", 0) or 0)
                            except Exception:
                                _bal = 0
                            _reason = "DRIFT" if gt.get("reason") == "drift_close" else "TP"
                            if not QUIET_MODE:
                                grid_notifier.on_trade_closed(
                                    gt["side"], gt["entry"], gt["exit"],
                                    gt["pnl"], _bal, tracker.win_rate(),
                                    tracker.total(), _reason,
                                )
                                try:
                                    broadcast_grid_event("trade", {"side": gt["side"], "entry": gt["entry"], "exit": gt["exit"], "pnl": gt["pnl"], "total_pnl": grid.pnl})
                                except Exception:
                                    pass
                elif grid:
                    # Grid deactivated by ATR — close all open positions
                    if grid_was_active and not grid.active:
                        try:
                            t = exchange.fetch_ticker(config.symbol)
                            deact_trades = grid.deactivate(t["last"]) or []
                        except Exception:
                            deact_trades = []
                        for gt in deact_trades:
                            tracker.record(gt["pnl"])
                            if paper_mode and hasattr(executor, 'cash'):
                                executor.cash += gt["pnl"]
                            close_side = "GRID_CLOSE_BUY" if gt["side"] == "buy" else "GRID_CLOSE_SELL"
                            db.log_trade(
                                config.symbol, close_side,
                                gt["entry"], GRID_SIZE / gt["entry"],
                                GRID_SIZE, gt["pnl"],
                                direction="long" if gt["side"] == "buy" else "short",
                                entry_price=gt.get("entry"),
                                exit_price=gt.get("exit"),
                                exit_reason="grid_deactivate",
                                strategy_version="grid_v1",
                                strategy_intent="grid_mean_reversion",
                                trigger_rule="grid_level",
                                instance_name=getattr(config, "instance_name", "live"),
                            )
                        # Push grid deactivation notification
                        if not QUIET_MODE:
                            grid_notifier._send(
                                "GRID OFF",
                                f"SOL PnL ${grid.pnl:+.2f} | {grid.trades} trades",
                            )
                            try:
                                broadcast_grid_event("deactivated", {"pnl": grid.pnl, "trades": grid.trades})
                            except Exception:
                                pass
                        grid_was_active = False

            # Save state file every loop (for crash recovery + dashboard)
            if hasattr(executor, '_save_state'):
                executor._save_state(grid.get_status() if grid else {})

            # Publish to Cloudflare KV (for web dashboard) — never from shadow
            if not QUIET_MODE:
                try:
                    publish_to_kv()
                except Exception as e:
                    logger.debug(f"[KV] Publish failed: {e}")

            time.sleep(config.scan_interval_seconds)

        except KeyboardInterrupt:
            break
        except Exception as e:
            logger.error(f"[SNIPER] Main loop error: {e}", exc_info=True)
            time.sleep(10)

    # ── Exit ──
    logger.info("[SNIPER] Shutting down...")
    # Save sniper position for recovery on restart (do NOT close)
    executor._save_state()
    logger.info(f"[SNIPER] Position state saved for restart")
    # Save grid state for recovery on restart (do NOT close positions)
    if grid:
        try:
            grid._save_state()
            gs = grid.get_status()
            filled = sum(1 for o in grid.grid_orders.values() if o.get("filled"))
            logger.info(f"[GRID] State saved for restart | {filled} filled positions preserved | PnL ${gs['pnl']:+.2f} | Trades {gs['trades']}")
        except Exception:
            pass

    if tracker.trades > 0:
        wr = tracker.wins / tracker.trades * 100
        logger.info(
            f"[SNIPER DAILY] {tracker.date} | "
            f"Trades: {tracker.trades} | Win rate: {wr:.0f}% | PnL: ${tracker.pnl:+.2f}"
        )

    total_pnl = db.get_total_pnl()
    logger.info(f"[SNIPER] Total PnL: ${total_pnl:+.2f}")
    logger.info("[SNIPER] Exited")


if __name__ == "__main__":
    main()
