        logger.info(f"[SNIPER] Regime gate: ON | window={REGIME_GATE_WINDOW_DAYS}d "
                    f"dominance={REGIME_GATE_DOMINANCE_PCT:.0f}pp refresh={REGIME_GATE_REFRESH_SECONDS}s")
    else:
        logger.info(f"[SNIPER] Regime gate: OFF (set STRATEGY_REGIME_GATE=1 to enable)")
    if grid:
        logger.info(f"[SNIPER] Micro-grid: {GRID_LEVELS*2} levels x ${GRID_SIZE:.0f} | 0.5% spacing | {GRID_SIDE} | 3x leverage")
    else:
        logger.info("[SNIPER] Grid: DISABLED (--no-grid)")
    logger.info(f"[SNIPER] Scanning...")

    # ── Main loop ──
    last_scan = 0

    # Reverse-signal exit (shadow feature, env-gated). Live plist does not
