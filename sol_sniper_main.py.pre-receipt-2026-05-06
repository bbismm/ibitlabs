    reverse_exit_enabled = os.environ.get("SNIPER_REVERSE_EXIT") == "1"
    reverse_exit_mode_c = os.environ.get("SNIPER_REVERSE_EXIT_MODE") == "C"
    last_reverse_check = 0
    reentry_gate_dir = None  # mode C: opposite direction to wait out before re-entering
    if reverse_exit_enabled:
        logger.info(
            f"[SNIPER] Reverse-signal exit: ON | mode={'C' if reverse_exit_mode_c else 'A'}"
        )

    while running:
        try:
            now = time.time()
            tracker.check_new_day()

            # Surface upstream gate state for the dashboard (cooldown,
