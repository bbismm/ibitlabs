def signal_handler(sig, frame):
    global running
    # Capture WHO sent the signal so the next "mystery shutdown" doesn't
    # require log forensics. PPID-cmdline tells us if it was launchctl
    # (kickstart -k), the ghost-watchdog (bootout), a script in scripts/,
    # or an ad-hoc operator kill. macOS lacks /proc, so use `ps -p`.
    # Two unexplained kills (2026-04-30 02:34 EDT and 2026-05-01 15:40 EDT)
    # left a forensic gap that this 8-line patch closes once and for all.
    try:
        import signal as _s, subprocess as _sp
        sig_name = _s.Signals(sig).name
        ppid = os.getppid()
        ppid_cmd = _sp.run(["ps", "-p", str(ppid), "-o", "command="],
                           capture_output=True, text=True, timeout=2).stdout.strip()
        logger.info(f"[SNIPER] Received shutdown signal {sig} ({sig_name}) "
                    f"from PPID={ppid} cmd={ppid_cmd!r}, my PID={os.getpid()}, "
                    f"preparing to exit...")
    except Exception as _e:
        logger.info(f"[SNIPER] Received shutdown signal (sig={sig}, "
                    f"ppid-introspect-failed: {_e}), preparing to exit...")
    running = False


sig_module.signal(sig_module.SIGINT, signal_handler)
sig_module.signal(sig_module.SIGTERM, signal_handler)


class DailyTracker:
    """Daily trade statistics"""
    def __init__(self):
        self.date = time.strftime("%Y-%m-%d")
        self.trades = 0
        self.wins = 0
        self.losses = 0
        self.pnl = 0.0

    def check_new_day(self):
        today = time.strftime("%Y-%m-%d")
        if today != self.date:
            if self.trades > 0:
                wr = self.wins / self.trades * 100
                logger.info(
                    f"[SNIPER DAILY] {self.date} | "
                    f"Trades: {self.trades} | Win rate: {wr:.0f}% | "
                    f"PnL: ${self.pnl:+.2f}"
                )
            self.date = today
            self.trades = 0
            self.wins = 0
            self.losses = 0
            self.pnl = 0.0

    def record(self, pnl: float):
        self.trades += 1
        self.pnl += pnl
        if pnl > 0:
            self.wins += 1
        else:
            self.losses += 1

    def win_rate(self) -> float:
        return (self.wins / self.trades * 100) if self.trades > 0 else 0

    def total(self) -> int:
        return self.trades

GATE_STATE_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                               "sol_sniper_gate_state.json")


def _write_gate_state(*, now: float, cooldown_until: float, consecutive_sl: int,
                      circuit_breaker_limit: int, reentry_gate_dir) -> None:
    """Persist upstream gate state for the dashboard. Atomic write; never raises.
    Daily-profit-target is intentionally not surfaced — the gate still runs
    in the loop, just not exposed publicly."""
    state = {
        "ts": int(now),
        "cooldown_until": int(cooldown_until),
        "cooldown_remaining_sec": max(0, int(cooldown_until - now)),
        "cooldown_active": now < cooldown_until,
        "consecutive_sl": consecutive_sl,
        "circuit_breaker_limit": circuit_breaker_limit,
        "circuit_breaker_open": consecutive_sl >= circuit_breaker_limit,
        "reentry_gate_dir": reentry_gate_dir,
    }
    try:
        tmp = GATE_STATE_PATH + ".tmp"
        with open(tmp, "w") as f:
            json.dump(state, f)
        os.replace(tmp, GATE_STATE_PATH)
    except Exception as e:
        logger.debug(f"[SNIPER] gate_state write failed: {e}")


